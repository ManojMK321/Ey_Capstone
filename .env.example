# Copy to .env and fill in real values. Never commit .env — it's gitignored.

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT_NAME;AccountKey=YOUR_ACCOUNT_KEY;EndpointSuffix=core.windows.net
AZURE_STORAGE_ACCOUNT_NAME=your_account_name
AZURE_STORAGE_ACCOUNT_KEY=your_account_key
AZURE_STORAGE_CONTAINER_NAME=contracts

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ── LangSmith (LLM call tracing — see src/observability/langsmith.py) ────────
# Tracing is off unless LANGSMITH_TRACING is one of 1/true/yes/on.
# Get an API key at https://smith.langchain.com/settings — treat it as a
# secret exactly like OPENAI_API_KEY; never commit or log it.
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_your-langsmith-api-key
LANGSMITH_PROJECT=contract-intelligence

# ── PostgreSQL (session store) ────────────────────────────────────────────────
# Either DATABASE_URL, or the POSTGRES_* fields below (DATABASE_URL wins).
DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=contract_intelligence
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_SSLMODE=

# ── Pinecone (vector store) ───────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=contract-intelligence

# ── Anthropic (optional) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ── Observability (all optional — see src/observability/) ───────────────────
LOG_LEVEL=INFO
# OpenTelemetry span export target; unset = spans print to stdout instead.
OTEL_EXPORTER_OTLP_ENDPOINT=
